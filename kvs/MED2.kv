    FloatLayout:
        id: temporary
        orientation: "vertical"
        size: root.width,root.height
        pos_hint:{"center_x": 0.5, "center_y": 0.5}

    FloatLayout:
        id: top
        orientation: "vertical"
        size: root.width,root.height
        pos_hint:{"center_x": 0.5, "center_y": 0.5}

        # top base
        Image:
            text: ''
            size_hint_x: 1
            size_hint_y: 0.05
            pos_hint:{"center_x":0.5,"center_y":0.975}
            color: root.color_of_top

        # settings text
        Label:
            text: root.buttons[950][0][0]
            font_name: "Sony"
            font_size: 0.03  * root.height
            size_hint: None, None
            size: self.texture_size
            pos_hint:{"x": 0.035,"center_y":1-0.025}
            color: root.color_of_top_text #41 / 255, 145 / 255, 43 / 255, 1

        # line
        Image:
            opacity: 1
            text: ''
            size_hint_x: 1
            size_hint_y: 0.003
            pos_hint:{"center_x":0.5,"center_y":0.95}
            color: root.color_of_top_line




        # music picto not
        Image:
            opacity: 1

    #text: '1'
    #size_hint_x: 1
    #size_hint_y: 0.06
    #pos_hint: {"center_x":0.5,"center_y":0.5}
    #canvas.before:
        #Color:
            #rgba: 0,1,1,1
        #Rectangle:
            #size: self.size
            #pos: self.pos

<Drag@Image>
    text: ' '
    size_hint_x: 1
    size_hint_y: 0.06
    pos_hint:{"center_x":0.5,"center_y":0.5}
    color: 0,1,1,1 # root.color_of_button

<Drag_Text@Label>
    text: " " #root.buttons[940][0][0]
    font_name: "Sony"
    font_size: 0.04  #0.04  * root.height
    size_hint: None, None
    size: self.texture_size
    # pos_hint:{"x":0.05,"center_y":root.position_of_first_row + 0.005}
    pos_hint:{"x":0.05,"center_y":0.5}
    color: 0,0,0,1 # root.color_of_arrow  #root.color_of_first_button_text
 # arrow
<Drag_Image@Image>
    opacity: 1 #root.opacity_of_arrow
    source:  "r_right.png" #root.arrow
    size_hint_x: 0.06
    size_hint_y: 0.06
    #pos_hint:{"center_x":0.95,"center_y":root.position_of_first_row}
    pos_hint:{"center_x":0.95,"center_y":0.5}
    color: 41/255, 145/255, 43/255, 1 # root.color_of_arrow

<Drag_Number@Label>
    opacity: 1 # 0
    text: " "  # f"{root.tap_counter}th"
    font_name: "Sony"
    font_size: 0.04  # * root.height
    size_hint: None, None
    size: self.texture_size
    #pos_hint:{"x":0.05,"center_y":root.position_of_first_number}
    pos_hint:{"x":0.05,"center_y": 0.5}
    color: 41/255, 145/255, 43/255, 1  # root.color_of_text





R2Window:

    name: 'R2'

    FloatLayout:
        id: background_lines
        orientation: "vertical"
        size: root.width,root.height
        Label:
            text: ''
            size_hint_x: 1
            size_hint_y: 1
            pos_hint:{"center_x":0.5,"center_y":0.5}
            canvas.before:
                Color:
                    rgba: 200/255, 203/255, 202/255, 255/255
                    #rgba: 0, 1, 0, 1
                Rectangle:
                    size: self.size
                    pos: self.pos


    FloatLayout:
        id: all_none
        orientation: "vertical"
        size: root.width,root.height
        pos_hint:{"center_x": 0.5, "center_y":root.position_of_row}

        # button on top above
        Image:
            size_hint_x: 1
            size_hint_y: 0.06
            pos_hint:{"center_x":0.5,"center_y":root.position_of_first_row}
            color: root.color_of_first_button
        # text
        Label:
            text: root.buttons[940][0][0]
            font_name: "Sony"
            font_size: 0.04  * root.height
            size_hint: None, None
            size: self.texture_size
            pos_hint:{"x":0.05,"center_y":root.position_of_first_row + 0.005}
            color: root.color_of_arrow  #root.color_of_first_button_text
        # arrow
        Image:
            opacity: root.opacity_of_arrow
            source: root.arrow
            size_hint_x: 0.06
            size_hint_y: 0.06
            pos_hint:{"center_x":0.95,"center_y":root.position_of_first_row}
            color: root.color_of_arrow



    FloatLayout:
        id: buttons
        orientation: "vertical"
        size: root.width,root.height
        pos_hint:{"center_x": 0.5, "center_y":root.position_of_row}


        # first row
        Image:
            text: '1'
            size_hint_x: 1
            size_hint_y: 0.06
            pos_hint:{"center_x":0.5,"center_y":root.position_of_first_row - root.rate * 1}
            color: root.color_of_button
        #Label:
            #pos_hint:{"center_x":0.5,"center_y":root.position_of_first_row - root.rate * 1}
            #text: '1'
            #size_hint_x: 1
            #size_hint_y: 0.06
            #canvas.before:
                #Color:
                    #rgba: 1,1,1,1
                #Rectangle:
                    #size: self.size
                    #pos: self.pos

        # text
        Label:
            text: root.buttons[109][0]
            font_name: "Sony"
            font_size: 0.04  * root.height
            size_hint: None, None
            size: self.texture_size
            pos_hint:{"x":0.05,"center_y":root.position_of_first_row - root.rate * 1}
            color: root.color_of_button_text
        # arrow
        Image:
            opacity: root.opacity_of_arrows
            source: root.arrow
            size_hint_x: 0.06
            size_hint_y: 0.06
            pos_hint:{"center_x":0.95,"center_y":root.position_of_first_row - root.rate * 1}
            color: root.color_of_arrows


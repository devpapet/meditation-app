    FloatLayout:
        id: bottom
        orientation: "vertical"
        size: root.width,root.height
        pos_hint:{"center_x": 0.5, "center_y": 0.5}

        # bottom base
        Image:
            text: ''
            size_hint_x: 1
            size_hint_y: 0.078
            pos_hint:{"center_x":0.5,"center_y":0.035}
            color: root.color_of_bottom_button


        # menu picto
        Image:
            source: "r_set_100.png"
            size_hint_x: 0.075
            size_hint_y: 0.075
            pos_hint:{"x":0.11,"center_y":0.035}
            color: root.color_of_bottom_picto

        # player picto
        Image:
            source: "r_player_100.png"
            size_hint_x: 0.075
            size_hint_y: 0.075
            pos_hint:{"x":0.82,"center_y":0.035}
            color: root.color_of_bottom_picto
        # bottom arrow right
        Image:
            opacity: root.opacity_of_arrow_b
            source: root.arrow
            size_hint_x: 0.06
            size_hint_y: 0.06
            pos_hint:{"center_x":0.95,"center_y":0.035}
            color: root.color_of_arrow_b
        # bottom arrow left
        Image:
            opacity: root.opacity_of_arrow_b
            source: root.arrow
            size_hint_x: 0.06
            size_hint_y: 0.06
            pos_hint:{"center_x":0.05,"center_y":0.035}
            color: root.color_of_arrow_b
            canvas.before:
                PushMatrix
                Rotate:
                    axis: 0,1,0
                    angle: 180
                    origin: self.center
            canvas.after:
                PopMatrix


    FloatLayout:
        id: bottom_line
        orientation: "vertical"
        size: root.width,root.height
        pos_hint:{"center_x": 0.5, "center_y": 0.5}
        # line
        Image:
            text: ''
            size_hint_x: 1
            size_hint_y: 0.003
            pos_hint:{"center_x":0.5,"center_y":0.073}
            color: root.color_of_bottom_button_line

        Label:
            opacity: 1
            text: root.small_number
            font_name: "Sony"
            font_size: 0.035  * root.height
            size_hint: None, None
            size: self.texture_size
            pos_hint:{"center_x":0.5,"center_y":0.040}
            color: root.color_of_small_number

    FloatLayout:
        id: basic
        orientation: "vertical"
        size: root.width,root.height
        Label:
            text: ''
            size_hint_x: 1
            size_hint_y: 0.85
            pos_hint:{"center_x":0.5,"center_y":0.5}
            canvas.before:
                Color:
                    rgba: 1,0,1,0
                Rectangle:
                    size: self.size
                    pos: self.pos
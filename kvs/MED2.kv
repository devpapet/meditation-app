            size_hint_x: 0.05
            pos_hint:{"center_x":0.95,"center_y":1-0.025}
            color: root.color_of_top_picto
        Image:
            opacity: 1
            source: root.pictos[17][1]
            size_hint_y: 0.05
            size_hint_x: 0.05
            pos_hint:{"center_x":0.95,"center_y":1-0.025}
            color: root.color_of_top_picto

        # voice picto
        Image:
            opacity: 1
            source: root.pictos[11][0]
            size_hint_y: 0.05
            size_hint_x: 0.05
            pos_hint:{"center_x":0.85,"center_y":1-0.025}
            color: root.color_of_top_picto
        # language picto
        Image:
